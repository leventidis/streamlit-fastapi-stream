# ──────────────────────────────────────────────
# LLM Provider — choose ONE of the two options
# ──────────────────────────────────────────────

# Option A: Azure OpenAI (takes priority when both are set)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1          # deployment name in your Azure resource
OPENAI_API_VERSION=2024-02-01            # Azure API version

# Option B: Native OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1                  # model name (default: gpt-4.1)
